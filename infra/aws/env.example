# Copy to a local untracked file (e.g. .env.aws) — do not commit secrets.
# Placeholder names for future AWS deployment.

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Networking / runtime (examples — adjust to your IaC output)
VPC_ID=
PRIVATE_SUBNET_IDS=
PUBLIC_SUBNET_IDS=

# ECR / ECS (if using containers)
ECR_REPOSITORY_URI=
ECS_CLUSTER_NAME=
ECS_SERVICE_NAME_API=
ECS_SERVICE_NAME_WEB=

# RDS Postgres + pgvector (or Aurora)
DATABASE_URL=

# Secrets / parameters (prefer Secrets Manager ARNs in prod)
# OPENAI_API_KEY_ARN=
# BEDROCK_MODEL_ID=

# S3
S3_KNOWLEDGE_BUCKET=

# Optional: CloudFront / custom domain
# CLOUDFRONT_DISTRIBUTION_ID=
# DOMAIN_NAME=
