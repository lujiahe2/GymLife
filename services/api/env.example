# Copy to `.env` in this directory:  cp env.example .env
# Never commit `.env`.

# Auth — change in production (signs JWTs for login)
JWT_SECRET=change-me-to-a-long-random-string

# --- Ollama (local, recommended for GymLife) ---
# Install: https://ollama.com   Then:
#   ollama serve
#   ollama pull llama3.2
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# Ollama ignores this value; any non-empty string works. You may omit it if OPENAI_BASE_URL is set.
OPENAI_API_KEY=ollama
# Must match a name from `ollama list` (often `llama3.2` or `llama3.2:latest`).
OPENAI_MODEL=llama3.2

# --- Optional: OpenAI cloud instead ---
# Comment out OPENAI_BASE_URL above (or set to https://api.openai.com/v1), then:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
